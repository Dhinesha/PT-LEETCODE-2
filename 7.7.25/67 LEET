class Solution {
    public String addBinary(String l, String d) {
        StringBuilder res =new StringBuilder();
        int i =l.length() -1;
        int j =d.length() -1;
        int car=0;
        while(i>= 0 || j>= 0 || car !=0 ){
            int sum=car;
            if(i>=0){
                sum += l.charAt(i) -'0';
                i--;
            }
            if(j>=0){
                sum += d.charAt(j) -'0';
                j--;
            }
            res.append(sum %2);
            car=sum/2;
        }
        return res.reverse().toString();
    }
}


