 class Solution {
    public int strStr(String haystack, String needle) {
        int hayst=haystack.length();
        int needl=needle.length();
        for(int i=0;i<hayst -needl;i++){
            int j=0;
            while(j < needl && haystack.charAt(i+j) == needle.charAt(j)) {
                j++;
            }
            if(j== needl){
                return i;
            }
        }
        return -1;
    }
}
